NODE_ENV=development
HOST=127.0.0.1
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vianko_day?schema=public"

INITIAL_WORKSPACE_NAME="Vianko"
INITIAL_WORKSPACE_SLUG="vianko"
INITIAL_ADMIN_NAME="Isaac Serrano"
INITIAL_ADMIN_EMAIL="isaac.serrano@vianko.com.mx"
INITIAL_ADMIN_PASSWORD="change-me-before-production"
INITIAL_DEFAULT_AREA_NAME="TI"
INITIAL_DEFAULT_LOCALITY_NAME="GDL"
INITIAL_DEFAULT_LOCALITY_CODE="GDL"

JWT_ACCESS_SECRET="replace-with-strong-random-secret"
JWT_REFRESH_SECRET="replace-with-another-strong-random-secret"
TOKEN_HASH_SECRET="replace-with-token-hashing-secret"
JWT_ISSUER="vianko-day-api"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173"

# Generate with: openssl rand -base64 32
COMMENT_ENCRYPTION_KEY="replace-with-32-byte-base64-key"
